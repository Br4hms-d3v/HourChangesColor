<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Heure et Couleur utilisant Spring Batch</title>
    <style>
        body {
            background-color: {{backgroundColor}};
            color: {{textColor}};
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 15%;
            transition: background-color 0.5s, color 0.5s;
        }
        h1 {
            font-size: 4rem;
        }
        h2 {
            font-size: 2rem;
            margin-top: 20px;
        }
    </style>
</head>
<body>

<h1 id="time">{{time}}</h1>
<h2 id="message">{{message}}</h2>

<script>
    const evtSource = new EventSource("/sse/colors");

    evtSource.addEventListener("color", event => {
        const data = JSON.parse(event.data);

        // 🔥 Les bons noms de champs
        document.body.style.backgroundColor = data.backgroundColor;
        document.body.style.color = data.textColor;

        // 🔥 Les bons IDs
        document.getElementById("time").innerText = data.time;
        document.getElementById("message").innerText = data.message;
    });
</script>

</body>
</html>
